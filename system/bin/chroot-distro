    fi
    chroot_distro_login "$1"
elif [ "$command" = "profile" ]; then
    PARSED=$(getopt --options= --longoptions= --name "$0" -- "$@") || chroot_distro_exit 2
    eval set -- "$PARSED"
    while true; do
        case "$1" in
            --)
                shift
                break
