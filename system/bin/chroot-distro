    fi
    case "$1" in
         enable) android_bind enable;; 
         disable) android_bind disable && chroot_distro_unmount "all" "yes" "yes";; 
         *) print_message error "Unknown option $1";; 
    esac
elif [ "$command" = "add" ]; then
